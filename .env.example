# PostgreSQL
POSTGRES_DB=bankdb
POSTGRES_USER=bankuser
POSTGRES_PASSWORD=change_me

# JWT — 64 hex chars (256-bit secret)
JWT_SECRET=change_me_to_64_hex_chars

# AES/GCM card encryption — exactly 32 chars (256-bit key)
CARD_ENCRYPTION_KEY=change_me_to_32_chars_exactly_xx

# Liquibase admin seed
DB_ADMIN_EMAIL=admin@bank.com
# BCrypt hash of the admin password (generate with: htpasswd -bnBC 12 "" password | tr -d ':\n')
DB_ADMIN_PASSWORD_HASH=$2a$12$replacethiswithrealbcrypthashxx

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
